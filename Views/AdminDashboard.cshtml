@using UmbracoReviewSite.Models;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = null;
    var istAdmin = Context.Request.Query["key"] == "admin123";
    var bewertungsRepo = new MockBewertungsRepository();
    var ausstehendeBewertungen = bewertungsRepo.HoleAusstehendeBewertungen().Result.ToList();
    var anzahlAusstehend = ausstehendeBewertungen.Count;
}

<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard - Umbraco Bewertungen</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        :root {
            --primary-red: #e30613;
            --dark-red: #c10510;
            --light-red: #fce4e4;
            --gray-bg: #f8f9fa;
            --text-dark: #333;
            --text-light: #666;
        }
        
        body {
            font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
            background: linear-gradient(135deg, var(--primary-red) 0%, var(--dark-red) 100%);
            min-height: 100vh;
            padding: 40px;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        
        .header {
            background: white;
            border-radius: 20px;
            padding: 30px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(227, 6, 19, 0.2);
        }
        
        .header h1 {
            font-size: 2em;
            color: var(--primary-red);
            margin-bottom: 10px;
        }
        
        .header p {
            font-size: 1.1em;
            color: var(--text-light);
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .stat-card {
            background: white;
            border-radius: 15px;
            padding: 25px;
            text-align: center;
            box-shadow: 0 5px 15px rgba(227, 6, 19, 0.1);
        }
        
        .stat-card h3 {
            font-size: 1.2em;
            color: var(--text-light);
            margin-bottom: 10px;
        }
        
        .stat-number {
            font-size: 2.5em;
            font-weight: 700;
            color: var(--primary-red);
        }
        
        .reviews-section {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(227, 6, 19, 0.1);
        }
        
        .section-title {
            font-size: 1.5em;
            color: var(--primary-red);
            margin-bottom: 20px;
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
        }
        
        th {
            background: var(--primary-red);
            color: white;
            padding: 12px;
            font-size: 0.95em;
            font-weight: 600;
            text-align: center;
        }
        
        td {
            padding: 12px;
            border-bottom: 1px solid var(--light-red);
            text-align: center;
            font-size: 0.95em;
        }
        
        tr:hover {
            background: var(--light-red);
        }
        
        .user-info {
            display: flex;
            flex-direction: column;
        }
        
        .user-name {
            font-weight: 600;
            color: var(--text-dark);
        }
        
        .user-email {
            color: var(--text-light);
            font-size: 0.85em;
        }
        
        .stars {
            color: #ffc107;
            font-size: 1.1em;
            white-space: nowrap;
        }
        
        .status-badge {
            background: var(--primary-red);
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85em;
            font-weight: 600;
            display: inline-block;
        }
        
        .action-buttons {
            display: flex;
            gap: 8px;
            justify-content: center;
        }
        
        .btn {
            border: none;
            padding: 6px 15px;
            border-radius: 20px;
            cursor: pointer;
            font-size: 0.9em;
            font-weight: 500;
            transition: all 0.2s;
            min-width: 90px;
        }
        
        .btn-approve {
            background: #28a745;
            color: white;
        }
        
        .btn-approve:hover {
            background: #218838;
        }
        
        .btn-reject {
            background: #6c757d;
            color: white;
        }
        
        .btn-reject:hover {
            background: #5a6268;
        }
        
        .empty-state {
            text-align: center;
            padding: 40px;
            color: var(--text-light);
            font-size: 1.1em;
            background: var(--light-red);
            border-radius: 10px;
        }
        
        .login-container {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .login-box {
            background: white;
            border-radius: 20px;
            padding: 40px;
            width: 400px;
            text-align: center;
            box-shadow: 0 20px 40px rgba(227, 6, 19, 0.2);
        }
        
        .login-box h2 {
            color: var(--primary-red);
            font-size: 2em;
            margin-bottom: 20px;
        }
        
        .login-box input {
            width: 100%;
            padding: 12px;
            margin: 10px 0;
            border: 2px solid #e0e0e0;
            border-radius: 30px;
            font-size: 1em;
        }
        
        .login-box input:focus {
            border-color: var(--primary-red);
            outline: none;
        }
        
        .login-box button {
            width: 100%;
            padding: 12px;
            background: var(--primary-red);
            color: white;
            border: none;
            border-radius: 30px;
            cursor: pointer;
            font-size: 1.1em;
            font-weight: 600;
            margin-top: 10px;
        }
        
        .login-box button:hover {
            background: var(--dark-red);
        }
        
        .badge {
            background: var(--primary-red);
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            display: inline-block;
            margin-bottom: 15px;
            font-size: 0.9em;
        }
    </style>
</head>
<body>
    <div class="container">
        @if (istAdmin)
        {
            <div class="header">
                <div class="badge">👑 Admin Dashboard</div>
                <h1>Verwaltung der Umbraco-Bewertungen</h1>
                <p>Genehmigen oder ablehnen Sie neue Bewertungen, bevor sie auf der Website erscheinen</p>
            </div>

            <div class="stats-grid">
                <div class="stat-card">
                    <h3>Gesamtbewertungen</h3>
                    <div class="stat-number">@anzahlAusstehend</div>
                </div>
                <div class="stat-card">
                    <h3>Warten auf Überprüfung</h3>
                    <div class="stat-number">@anzahlAusstehend</div>
                </div>
            </div>

            <div class="reviews-section">
                <h2 class="section-title">📝 Ausstehende Bewertungen</h2>
                
                @if (ausstehendeBewertungen.Any())
                {
                    <table>
                        <thead>
                            <tr>
                                <th>Benutzer</th>
                                <th>Bewertung</th>
                                <th>Kommentar</th>
                                <th>Datum</th>
                                <th>Status</th>
                                <th>Aktionen</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var bewertung in ausstehendeBewertungen)
                            {
                                <tr>
                                    <td>
                                        <div class="user-info">
                                            <span class="user-name">@bewertung.AutorenName</span>
                                            <span class="user-email">@bewertung.AutorenEmail</span>
                                        </div>
                                    </td>
                                    <td class="stars">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <span>@(i <= bewertung.SterneBewertung ? "★" : "☆")</span>
                                        }
                                    </td>
                                    <td>@bewertung.Kommentar</td>
                                    <td>@bewertung.ErstellungsDatum.ToString("dd.MM.yyyy")</td>
                                    <td>
                                        <span class="status-badge">
                                            ⏳ Wartet
                                        </span>
                                    </td>
                                    <td>
                                        <div class="action-buttons">
                                            <form method="post" action="/umbraco/api/BewertungsApi/Genehmigen" style="display:inline;">
                                                <input type="hidden" name="bewertungsId" value="@bewertung.Id" />
                                                <button type="submit" class="btn btn-approve">✓ Genehmigen</button>
                                            </form>
                                            <form method="post" action="/umbraco/api/BewertungsApi/Ablehnen" style="display:inline;">
                                                <input type="hidden" name="bewertungsId" value="@bewertung.Id" />
                                                <button type="submit" class="btn btn-reject">✗ Ablehnen</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state">
                        ✨ Keine Bewertungen warten auf Überprüfung
                    </div>
                }
            </div>
        }
        else
        {
            <div class="login-container">
                <div class="login-box">
                    <div class="badge">🔐 Admin Login</div>
                    <h2>Willkommen zurück</h2>
                    <form method="get">
                        <input type="password" name="key" placeholder="Passwort eingeben" />
                        <button type="submit">Anmelden</button>
                    </form>
                </div>
            </div>
        }
    </div>
</body>
</html>